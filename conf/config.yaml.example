# Search configuration
max_search_page: 50          # max pages to search (1-50)
max_video_per_author: 1000   # max videos to collect per author

# Concurrency configuration
concurrency: 2               # Worker Pool concurrency level (= browser Tab count, recommended 2; higher values may trigger 412 anti-crawl)
request_interval: 2500ms     # Delay between requests per worker (anti-crawl safe interval)

# Browser configuration
browser:
  headless: true                       # headless mode (server must be true, set false for local GUI login)
  user_data_dir: "data/browser-profile/" # browser profile directory for login state persistence

# Circuit breaker configuration
max_consecutive_failures: 10 # consecutive failures before aborting

# Output configuration
output_dir: "data/"          # CSV output directory

# Cookie configuration (headless mode fallback when user_data_dir has no login state)
# How to get cookie: open bilibili.com in browser → F12 → Network → copy Cookie header value
cookie: ""
