    # author_page_sort_by: "newest"     # author videos page sort: "newest" (default), "popular", "oldest"
    concurrency: 1            # YouTube concurrency (overrides global, strict anti-crawl)
    request_interval: 2500ms  # YouTube request interval (overrides global)
